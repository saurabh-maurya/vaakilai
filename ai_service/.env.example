# =============================================================================
# VakilAI AI Service — local development .env
# =============================================================================
#
# SETUP (local dev without Docker)
#   cp .env.example .env
#   Fill every [REQUIRED] line, then: uvicorn main:app --reload --port 8001
#
# For Docker deployments use the root .env instead (docker-compose reads it).
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDER
# Set AI_PROVIDER to choose which LLM backend to use.
# claude (default) → Anthropic Claude
# huggingface      → HuggingFace Inference API
# ollama           → Local Ollama server
# ─────────────────────────────────────────────────────────────────────────────

AI_PROVIDER=claude


# ─────────────────────────────────────────────────────────────────────────────
# AI — ANTHROPIC (Claude)
# https://console.anthropic.com/
# ─────────────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-CHANGE_ME                   # [REQUIRED if AI_PROVIDER=claude]
MODEL_NAME=claude-sonnet-4-6


# ─────────────────────────────────────────────────────────────────────────────
# AI — GOOGLE GEMINI  (optional multi-provider fallback)
# https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────────────────────

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro


# ─────────────────────────────────────────────────────────────────────────────
# AI — GROK / xAI  (optional multi-provider fallback)
# https://console.x.ai/
# ─────────────────────────────────────────────────────────────────────────────

GROK_API_KEY=
GROK_MODEL=grok-beta
GROK_BASE_URL=https://api.x.ai/v1


# ─────────────────────────────────────────────────────────────────────────────
# AI — HUGGINGFACE  (only if AI_PROVIDER=huggingface)
# https://huggingface.co/settings/tokens
# ─────────────────────────────────────────────────────────────────────────────

HUGGINGFACE_API_TOKEN=
HF_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_PREDICTION_MODEL=                # Optional: fine-tuned DistilBERT model ID on HF Hub


# ─────────────────────────────────────────────────────────────────────────────
# AI — OLLAMA  (only if AI_PROVIDER=ollama)
# Install Ollama: https://ollama.com/
# Pull model: ollama pull phi3:mini && ollama pull nomic-embed-text
# ─────────────────────────────────────────────────────────────────────────────

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=phi3:mini
OLLAMA_EMBEDDING_MODEL=nomic-embed-text


# ─────────────────────────────────────────────────────────────────────────────
# AI — AALAP  (OpenNyAI Mistral 7B fine-tuned for Indian legal tasks)
# Requires HUGGINGFACE_API_TOKEN. Cold start ~20s on HF free tier.
# ─────────────────────────────────────────────────────────────────────────────

AALAP_ENABLED=false
AALAP_MODEL=opennyaiorg/Aalap-Mistral-7B-v0.1-bf16


# ─────────────────────────────────────────────────────────────────────────────
# VECTOR SEARCH — Pinecone  (cloud; leave blank to use local FAISS)
# https://app.pinecone.io/
# ─────────────────────────────────────────────────────────────────────────────

PINECONE_API_KEY=
PINECONE_INDEX_NAME=vakilai-judgments
PINECONE_ENVIRONMENT=us-east-1-aws


# ─────────────────────────────────────────────────────────────────────────────
# VECTOR SEARCH — FAISS  (local; used when Pinecone is not configured)
# ─────────────────────────────────────────────────────────────────────────────

FAISS_INDEX_PATH=./data/faiss_index
CASES_DATA_PATH=./data/cases


# ─────────────────────────────────────────────────────────────────────────────
# NYAYAANUMANA DATASET  (IIT Kanpur 702k judgment dataset for bulk ingestion)
# ─────────────────────────────────────────────────────────────────────────────

NYAYAANUMANA_DATASET=Exploration-Lab/NyayaAnumana
NYAYAANUMANA_BATCH_SIZE=500         # Cases per FAISS batch (tune for available RAM)
NYAYAANUMANA_MAX_CASES=0            # 0 = ingest all; set N to limit (useful for dev)


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — MongoDB  (shared with backend)
# ─────────────────────────────────────────────────────────────────────────────

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=vakilai


# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION — JWT
# Must be identical to the backend's JWT_SECRET.
# ─────────────────────────────────────────────────────────────────────────────

JWT_SECRET=CHANGE_ME_at_least_32_random_chars        # [REQUIRED — must match backend]
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60


# ─────────────────────────────────────────────────────────────────────────────
# INTERNAL SERVICE AUTH
# Must match INTERNAL_SERVICE_KEY in backend/.env.
# ─────────────────────────────────────────────────────────────────────────────

INTERNAL_SERVICE_KEY=CHANGE_ME_at_least_32_chars     # [REQUIRED in production]


# ─────────────────────────────────────────────────────────────────────────────
# EXTERNAL APIs
# ─────────────────────────────────────────────────────────────────────────────

# eCourts open API (free, no key needed by default)
ECOURTS_API_URL=https://eciapi.akshit.me

# Twilio (used for WhatsApp AI responses)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ODR — Presolv360 (leave blank for AI-only wizard mode)
ODR_PROVIDER_API_KEY=
ODR_PROVIDER_URL=https://api.presolv360.com

# Jitsi video (leave JITSI_APP_ID blank for public meet.jit.si)
JITSI_DOMAIN=meet.jit.si
JITSI_APP_ID=


# ─────────────────────────────────────────────────────────────────────────────
# CACHE — Redis
# ─────────────────────────────────────────────────────────────────────────────

REDIS_URL=                          # e.g. redis://:password@localhost:6379/1


# ─────────────────────────────────────────────────────────────────────────────
# MONITORING
# ─────────────────────────────────────────────────────────────────────────────

METRICS_TOKEN=
SENTRY_DSN=


# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000
