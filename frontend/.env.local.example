# =============================================================================
# VakilAI Frontend — local development .env.local
# =============================================================================
#
# SETUP
#   cp .env.local.example .env.local
#   Then: npm run dev
#
# NEXT_PUBLIC_* variables are embedded in the browser bundle at build time.
# NEVER put secrets in NEXT_PUBLIC_* variables.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# SERVICE URLS
# Point these at your running backend and AI service.
# In production, use your deployed domain (e.g. https://api.vakilai.in).
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_AI_URL=http://localhost:8001


# ─────────────────────────────────────────────────────────────────────────────
# APP METADATA
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_NAME=VakilAI


# ─────────────────────────────────────────────────────────────────────────────
# PAYMENTS — Razorpay (public key only — secret stays on the backend)
# Use rzp_test_* in development, rzp_live_* in production.
# https://dashboard.razorpay.com/app/keys
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_CHANGE_ME
