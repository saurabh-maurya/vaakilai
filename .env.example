# =============================================================================
# VakilAI — Root .env  (used by docker-compose.yml)
# =============================================================================
#
# SETUP
#   cp .env.example .env
#   Fill every [REQUIRED] line before running: docker compose up -d
#   [OPTIONAL] lines have safe defaults or are feature-gated (leave blank to
#   disable that feature).
#
# SECRET GENERATION — run each once and paste the output:
#   JWT_SECRET            python -c "import secrets; print(secrets.token_hex(32))"
#   INTERNAL_SERVICE_KEY  python -c "import secrets; print(secrets.token_hex(32))"
#   CONFIG_ENCRYPTION_KEY python -c "import secrets; print(secrets.token_hex(32))"
#   METRICS_TOKEN         openssl rand -hex 32
#   MONGO_ROOT_PASSWORD   python -c "import secrets; print(secrets.token_hex(24))"
#   REDIS_PASSWORD        python -c "import secrets; print(secrets.token_hex(16))"
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — MongoDB
# ─────────────────────────────────────────────────────────────────────────────

MONGO_ROOT_USER=vakilai
MONGO_ROOT_PASSWORD=CHANGE_ME_strong_password        # [REQUIRED]
MONGODB_DB_NAME=vakilai


# ─────────────────────────────────────────────────────────────────────────────
# CACHE — Redis
# ─────────────────────────────────────────────────────────────────────────────

REDIS_PASSWORD=CHANGE_ME_redis_password              # [REQUIRED]
# Full URL is constructed in docker-compose; set here only for local dev
# REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6379/0


# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION — JWT
# Must be identical in backend and ai_service.
# Changing this invalidates all active user sessions.
# ─────────────────────────────────────────────────────────────────────────────

JWT_SECRET=CHANGE_ME_at_least_32_random_chars        # [REQUIRED]
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60


# ─────────────────────────────────────────────────────────────────────────────
# INTERNAL SERVICE AUTH
# Shared secret for backend → ai_service calls. Must match in both services.
# ─────────────────────────────────────────────────────────────────────────────

INTERNAL_SERVICE_KEY=CHANGE_ME_at_least_32_chars     # [REQUIRED in production]


# ─────────────────────────────────────────────────────────────────────────────
# ADMIN CONFIG STORE ENCRYPTION
# AES-256-GCM master key for secrets stored via the admin dashboard.
# Without this, DB config values won't survive a service restart.
# ─────────────────────────────────────────────────────────────────────────────

CONFIG_ENCRYPTION_KEY=CHANGE_ME_at_least_32_chars    # [REQUIRED for config store]


# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=production                  # development | production
DEBUG=false
CORS_ORIGINS=http://localhost:3000  # comma-separated; add your frontend domain in prod


# ─────────────────────────────────────────────────────────────────────────────
# AI — ANTHROPIC (Claude)
# https://console.anthropic.com/
# ─────────────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-CHANGE_ME                   # [REQUIRED for AI features]
CLAUDE_MODEL=claude-sonnet-4-6
AI_PROVIDER=claude                  # claude | huggingface | ollama


# ─────────────────────────────────────────────────────────────────────────────
# AI — HUGGINGFACE  (alternative provider; only if AI_PROVIDER=huggingface)
# https://huggingface.co/settings/tokens
# ─────────────────────────────────────────────────────────────────────────────

HUGGINGFACE_API_TOKEN=
HF_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2


# ─────────────────────────────────────────────────────────────────────────────
# AI — GOOGLE GEMINI  (optional multi-provider support)
# https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────────────────────

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro


# ─────────────────────────────────────────────────────────────────────────────
# AI — GROK / xAI  (optional multi-provider support)
# https://console.x.ai/
# ─────────────────────────────────────────────────────────────────────────────

GROK_API_KEY=
GROK_MODEL=grok-beta
GROK_BASE_URL=https://api.x.ai/v1


# ─────────────────────────────────────────────────────────────────────────────
# AI — PINECONE  (cloud vector DB; leave blank to use local FAISS instead)
# https://app.pinecone.io/
# ─────────────────────────────────────────────────────────────────────────────

PINECONE_API_KEY=
PINECONE_INDEX=vakilai-judgments
PINECONE_ENV=us-east-1-aws


# ─────────────────────────────────────────────────────────────────────────────
# AI — FAISS  (local vector search; used when Pinecone is not configured)
# ─────────────────────────────────────────────────────────────────────────────

FAISS_INDEX_PATH=./data/faiss_index
CASES_DATA_PATH=./data/cases


# ─────────────────────────────────────────────────────────────────────────────
# STORAGE — AWS S3
# IAM permissions required: s3:PutObject, s3:GetObject, s3:DeleteObject
# on both buckets.
# ─────────────────────────────────────────────────────────────────────────────

AWS_ACCESS_KEY_ID=                                   # [REQUIRED for document upload]
AWS_SECRET_ACCESS_KEY=                               # [REQUIRED for document upload]
AWS_REGION=ap-south-1
S3_BUCKET_DOCUMENTS=vakilai-documents
S3_BUCKET_INVOICES=vakilai-invoices


# ─────────────────────────────────────────────────────────────────────────────
# PAYMENTS — Razorpay
# https://dashboard.razorpay.com/app/keys
# Use rzp_test_* keys in development, rzp_live_* in production.
# ─────────────────────────────────────────────────────────────────────────────

RAZORPAY_KEY_ID=rzp_test_CHANGE_ME                   # [REQUIRED for payments]
RAZORPAY_KEY_SECRET=CHANGE_ME                        # [REQUIRED for payments]


# ─────────────────────────────────────────────────────────────────────────────
# COMMUNICATION — Twilio  (SMS + WhatsApp)
# https://console.twilio.com/
# ─────────────────────────────────────────────────────────────────────────────

TWILIO_ACCOUNT_SID=                                  # [REQUIRED for SMS/WhatsApp]
TWILIO_AUTH_TOKEN=                                   # [REQUIRED for SMS/WhatsApp]
TWILIO_PHONE_NUMBER=                                 # E.164 format e.g. +919876543210
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886         # Twilio sandbox default


# ─────────────────────────────────────────────────────────────────────────────
# COMMUNICATION — WhatsApp Business API (via Twilio)
# ─────────────────────────────────────────────────────────────────────────────

WHATSAPP_API_TOKEN=                                  # [REQUIRED for WhatsApp]
WHATSAPP_PHONE_ID=                                   # Twilio phone resource SID


# ─────────────────────────────────────────────────────────────────────────────
# VIDEO — Jitsi
# Leave JITSI_APP_ID blank to use the public meet.jit.si service (free).
# ─────────────────────────────────────────────────────────────────────────────

JITSI_DOMAIN=meet.jit.si
JITSI_APP_ID=                                        # [OPTIONAL] private Jitsi deployment


# ─────────────────────────────────────────────────────────────────────────────
# ODR — Online Dispute Resolution  (Presolv360)
# Leave blank to use the AI-only wizard (no external integration).
# ─────────────────────────────────────────────────────────────────────────────

ODR_PROVIDER_API_KEY=
ODR_PROVIDER_URL=https://api.presolv360.com


# ─────────────────────────────────────────────────────────────────────────────
# MONITORING — Prometheus metrics token
# Set in prometheus.yml as bearer_token so Prometheus can scrape /metrics.
# ─────────────────────────────────────────────────────────────────────────────

METRICS_TOKEN=CHANGE_ME_metrics_bearer_token         # [REQUIRED in production]


# ─────────────────────────────────────────────────────────────────────────────
# MONITORING — Sentry  (error tracking)
# https://sentry.io/ — create a project and copy the DSN.
# ─────────────────────────────────────────────────────────────────────────────

SENTRY_DSN=                                          # [OPTIONAL]


# ─────────────────────────────────────────────────────────────────────────────
# MONITORING — Grafana
# ─────────────────────────────────────────────────────────────────────────────

GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_pass        # [REQUIRED] Grafana UI login
