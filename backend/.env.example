# =============================================================================
# VakilAI Backend — local development .env
# =============================================================================
#
# SETUP (local dev without Docker)
#   cp .env.example .env
#   Fill every [REQUIRED] line, then: uvicorn main:app --reload --port 8000
#
# For Docker deployments use the root .env instead (docker-compose reads it).
#
# SECRET GENERATION:
#   JWT_SECRET            python -c "import secrets; print(secrets.token_hex(32))"
#   INTERNAL_SERVICE_KEY  python -c "import secrets; print(secrets.token_hex(32))"
#   CONFIG_ENCRYPTION_KEY python -c "import secrets; print(secrets.token_hex(32))"
#   METRICS_TOKEN         openssl rand -hex 32
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — MongoDB
# ─────────────────────────────────────────────────────────────────────────────

# Local MongoDB (no auth):
MONGODB_URL=mongodb://localhost:27017

# Local MongoDB with auth (matches docker-compose mongo service):
# MONGODB_URL=mongodb://vakilai:CHANGE_ME_strong_password@localhost:27017/vakilai?authSource=admin

# MongoDB Atlas (production):
# MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

MONGODB_DB_NAME=vakilai


# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION — JWT
# Must be identical in backend and ai_service.
# ─────────────────────────────────────────────────────────────────────────────

JWT_SECRET=CHANGE_ME_at_least_32_random_chars        # [REQUIRED]
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60


# ─────────────────────────────────────────────────────────────────────────────
# INTERNAL SERVICE AUTH
# Shared secret used when backend calls ai_service endpoints.
# Must match INTERNAL_SERVICE_KEY in ai_service/.env.
# ─────────────────────────────────────────────────────────────────────────────

INTERNAL_SERVICE_KEY=CHANGE_ME_at_least_32_chars     # [REQUIRED in production]


# ─────────────────────────────────────────────────────────────────────────────
# ADMIN CONFIG STORE ENCRYPTION
# AES-256-GCM master key for secrets stored via the admin dashboard.
# Per-entry PBKDF2-derived key + random salt; values are never stored plaintext.
# ─────────────────────────────────────────────────────────────────────────────

CONFIG_ENCRYPTION_KEY=CHANGE_ME_at_least_32_chars    # [REQUIRED for config store]


# ─────────────────────────────────────────────────────────────────────────────
# AI SERVICE
# ─────────────────────────────────────────────────────────────────────────────

AI_SERVICE_URL=http://localhost:8001


# ─────────────────────────────────────────────────────────────────────────────
# STORAGE — AWS S3
# ─────────────────────────────────────────────────────────────────────────────

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_DOCUMENTS=vakilai-documents
S3_BUCKET_INVOICES=vakilai-invoices


# ─────────────────────────────────────────────────────────────────────────────
# PAYMENTS — Razorpay
# https://dashboard.razorpay.com/app/keys
# ─────────────────────────────────────────────────────────────────────────────

RAZORPAY_KEY_ID=rzp_test_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME


# ─────────────────────────────────────────────────────────────────────────────
# COMMUNICATION — Twilio
# ─────────────────────────────────────────────────────────────────────────────

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=


# ─────────────────────────────────────────────────────────────────────────────
# CACHE — Redis
# Required for distributed rate limiting across multiple workers.
# Leave blank in single-worker local dev (falls back to in-memory).
# ─────────────────────────────────────────────────────────────────────────────

REDIS_URL=                          # e.g. redis://:password@localhost:6379/0


# ─────────────────────────────────────────────────────────────────────────────
# MONITORING
# ─────────────────────────────────────────────────────────────────────────────

METRICS_TOKEN=                      # Protects /metrics from unauthenticated scraping
SENTRY_DSN=                         # https://sentry.io/ — leave blank to disable


# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=development                 # development | production
DEBUG=true
CORS_ORIGINS=http://localhost:3000
